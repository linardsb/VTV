# VTV Production Environment
# Copy to .env.production and fill in real values.
# Usage: make docker-prod (reads .env.production automatically)

# Application
ENVIRONMENT=production
LOG_LEVEL=WARNING

# Database — CHANGE the password
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# Redis — optional password (leave empty to disable)
REDIS_PASSWORD=

# Auth — REQUIRED (generate with: openssl rand -base64 32)
AUTH_SECRET=

# CORS — your production domain(s)
ALLOWED_ORIGINS=["https://yourdomain.lv"]

# LLM Provider
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=

# Embedding Provider
EMBEDDING_PROVIDER=jina
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_API_KEY=

# GTFS auto-import on empty database
AUTO_IMPORT_GTFS=true

# Background poller
POLLER_ENABLED=true
