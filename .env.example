# Application
APP_NAME=VTV
VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api

# Database (for local development outside Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/vtv_db

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8123"]

# LLM Provider (uncomment when agent feature is implemented)
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5
# LLM_FALLBACK_PROVIDER=ollama
# LLM_FALLBACK_MODEL=llama3.1:70b

# Obsidian Vault (uncomment when agent feature is implemented)
# OBSIDIAN_API_KEY=your-obsidian-api-key
# OBSIDIAN_VAULT_URL=https://127.0.0.1:27124
