# Application
APP_NAME=VTV
VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api

# Database (for local development outside Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/vtv_db

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8123"]

# LLM Provider
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5-20250929
# LLM_FALLBACK_PROVIDER=ollama
# LLM_FALLBACK_MODEL=llama3.1:70b

# Transit GTFS-RT Feeds (Rigas Satiksme public endpoints — defaults work out of the box)
# GTFS_RT_VEHICLE_POSITIONS_URL=https://saraksti.rigassatiksme.lv/vehicle_positions.pb
# GTFS_RT_TRIP_UPDATES_URL=https://saraksti.rigassatiksme.lv/trip_updates.pb
# GTFS_RT_ALERTS_URL=https://saraksti.rigassatiksme.lv/gtfs_realtime.pb
# GTFS_STATIC_URL=https://saraksti.rigassatiksme.lv/gtfs.zip
# GTFS_RT_CACHE_TTL_SECONDS=20
# GTFS_STATIC_CACHE_TTL_HOURS=24

# Rate Limiting (requests per minute per IP)
# RATE_LIMIT_CHAT=10/minute
# RATE_LIMIT_TRANSIT=30/minute
# RATE_LIMIT_HEALTH=60/minute
# RATE_LIMIT_DEFAULT=120/minute

# Agent Query Quota (daily per IP)
# AGENT_DAILY_QUOTA=50

# Auth (REQUIRED - generate with: openssl rand -base64 32)
# AUTH_SECRET=<generate-a-real-secret>

# Obsidian Vault
OBSIDIAN_API_KEY=your-obsidian-api-key
OBSIDIAN_VAULT_URL=https://127.0.0.1:27124

# Embedding Provider (openai, jina, local)
EMBEDDING_PROVIDER=jina
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSION=1024
# EMBEDDING_API_KEY=your-jina-api-key
# EMBEDDING_BASE_URL=https://api.jina.ai/v1

# Reranker (local, none)
RERANKER_PROVIDER=local
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# RERANKER_TOP_K=10

# Document storage
DOCUMENT_STORAGE_PATH=data/documents

# Knowledge Base
# KNOWLEDGE_CHUNK_SIZE=512
# KNOWLEDGE_CHUNK_OVERLAP=50
# KNOWLEDGE_SEARCH_LIMIT=50
